APP_ENV=development
HTTP_ADDR=:8080

# Local dev uses a dedicated AI Gateway database.
DATABASE_URL=postgresql://genfity:dbgenfity2026@localhost:5432/genfity_ai_gateway?sslmode=disable
REDIS_URL=redis://localhost:6379/3
REDIS_PREFIX=ai-gateway:prod

GENFITY_AUTH_MODE=jwt
GENFITY_AUTH_JWKS_URL=
GENFITY_JWT_SECRET=CHANGE_THIS_TO_MATCH_GENFITY_APP_JWT_SECRET
GENFITY_INTERNAL_SECRET=CHANGE_THIS_SHARED_INTERNAL_SECRET

# Use localhost for bare local runs, or the container hostname in Docker compose.
NINE_ROUTER_CORE1_INTERNAL_URL=http://localhost:20128
NINE_ROUTER_CORE1_PUBLIC_URL=https://ai-core1.genfity.com
NINE_ROUTER_CORE1_API_KEY=

API_KEY_PEPPER=CHANGE_THIS_LONG_RANDOM_SECRET
ENCRYPTION_KEY=CHANGE_THIS_32_BYTE_SECRET

DEFAULT_CURRENCY=IDR
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=120
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=120000
CONCURRENT_LIMIT=5
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_RPM=300
GLOBAL_RATE_LIMIT_BURST=60

# Optional local seed overrides.
# SEED_USER_ID=11111111-1111-1111-1111-111111111111
# SEED_PLAN_CODE=local-dev
# SEED_MODEL_PUBLIC=genfity/test-model
# SEED_ROUTER_MODEL=openai/gpt-4o-mini
# SEED_RAW_KEY=sk_genfity_live_localseed_1234567890abcdefghijklmnopqrstuvwxyz

# Local bootstrap:
# 1. Run goose migration.
# 2. Run bash ./seed-local.sh.
# 3. Start 9Router on http://localhost:20128.
# 4. Start this service on http://localhost:8080.
# Note: /v1/chat/completions requires valid upstream provider credentials configured in 9Router.
