# ===================================================================================
# GENFITY AI GATEWAY SERVICE — Environment configuration
# ===================================================================================
#
# This file is the 1:1 template for production .env on the VPS and for
# the GitHub Actions `ENV_FILE` secret. The CI/CD pipeline writes the
# secret verbatim to /home/cicddeploy/genfity/genfity-ai-gateway/.env
# before `docker compose up`, so every variable listed here must have
# a real value in the secret.
#
# Local dev copies this file to `.env` (same file name inside Docker).
# Production values are managed in GitHub → Settings → Secrets → ENV_FILE.
#
# Changes here need a matching change in the secret — they don't auto-sync.
# ===================================================================================

# ── Runtime ─────────────────────────────────────────────────────────
APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=120

# ── Database ────────────────────────────────────────────────────────
# Production uses PostgreSQL on host.docker.internal. sslmode=disable is
# fine on the same host; for managed DBs switch to sslmode=require.
# goose migrations run automatically on container startup (see
# internal/database/migrate.go). Dedicated AI Gateway database, NOT
# the genfity-app database — keep schemas isolated.
DATABASE_URL=postgresql://genfity:dbgenfity2026@localhost:5432/genfity_ai_gateway?sslmode=disable

# ── Redis ───────────────────────────────────────────────────────────
# Rate limiter + ephemeral state. Prefix namespaces keys so multiple
# services can share one Redis instance without collisions.
REDIS_URL=redis://localhost:6379/3
REDIS_PREFIX=ai-gateway:prod

# ── Auth ────────────────────────────────────────────────────────────
# GENFITY_JWT_SECRET must match the genfity-app JWT secret (shared
# session manager). GENFITY_INTERNAL_SECRET is for sync endpoints
# (/internal/sync/*) — generate a fresh random string per environment.
# GENFITY_APP_URL is used by this gateway to post settled usage debits
# back to genfity-app, so the customer-facing credit balance is reduced.
GENFITY_AUTH_MODE=jwt
GENFITY_AUTH_JWKS_URL=
GENFITY_JWT_SECRET=CHANGE_THIS_TO_MATCH_GENFITY_APP_JWT_SECRET
GENFITY_INTERNAL_SECRET=CHANGE_THIS_SHARED_INTERNAL_SECRET
GENFITY_APP_URL=http://genfity-app:3000

# ── CLIProxyAPI upstream (ai-core2) ─────────────────────────────────
# The gateway forwards requests to CLIProxyAPI. INTERNAL_URL is used
# server-to-server (Docker network); PUBLIC_URL is surfaced to
# customers in /v1/models metadata. API_KEY is the management key for
# CLIProxyAPI's /v0/management/* endpoints (optional in dev).
AI_ROUTER_CORE2_INTERNAL_URL=http://localhost:8317
AI_ROUTER_CORE2_PUBLIC_URL=https://ai-core2.genfity.com
AI_ROUTER_CORE2_API_KEY=

# ── Crypto ──────────────────────────────────────────────────────────
# API_KEY_PEPPER salts Argon2 hashes of customer API keys. Losing it
# invalidates every live key — rotate only with a planned migration.
# ENCRYPTION_KEY must be exactly 32 bytes (AES-256).
API_KEY_PEPPER=CHANGE_THIS_LONG_RANDOM_SECRET
ENCRYPTION_KEY=CHANGE_THIS_32_BYTE_SECRET

# ── Rate limits (global fallback) ───────────────────────────────────
# Per-plan limits from the entitlement override these. The global
# limit is a safety net against run-away callers.
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_RPM=300
GLOBAL_RATE_LIMIT_BURST=60

# ── Billing ─────────────────────────────────────────────────────────
# Defaults that apply when a plan/credential doesn't override them.
DEFAULT_CURRENCY=IDR

# ── Local seed overrides (dev only) ─────────────────────────────────
# Uncomment to pre-populate a test user + API key via seed-local.sh.
# SEED_USER_ID=11111111-1111-1111-1111-111111111111
# SEED_PLAN_CODE=local-dev
# SEED_MODEL_PUBLIC=genfity/test-model
# SEED_ROUTER_MODEL=gpt-5
# SEED_RAW_KEY=sk_genfity_live_localseed_1234567890abcdefghijklmnopqrstuvwxyz

# Local bootstrap:
# 1. Start CLIProxyAPI on http://localhost:8317.
# 2. `cp .env.example .env` + edit DATABASE_URL / REDIS_URL if needed.
# 3. `go run ./cmd/http` — migrations auto-apply on boot.
# 4. Optionally: `bash ./seed-local.sh` to create a dev user.
